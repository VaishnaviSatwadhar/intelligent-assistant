{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartai drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartai drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10"
  }
}
