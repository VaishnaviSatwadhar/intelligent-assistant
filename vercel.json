{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/smart-ai run build",
  "outputDirectory": "artifacts/smart-ai/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
